      },
      {
        "datasource": { "type": "postgres", "uid": "pipeline-pg" },
        "enable": true,
        "hide": false,
        "iconColor": "red",
        "name": "Flash Sale Alerts",
        "rawQuery": true,
        "rawSql": "SELECT created_at AS time, product_id || ' — Flash Sale Triggered' AS text, 'Flash Sale' AS tags FROM flash_sale_alerts WHERE $__timeFilter(created_at) ORDER BY created_at",
        "showIn": 0,
        "type": "dashboard"
      }
    ]
  },
  "description": "Real-time clickstream analytics — views, conversions, flash-sale alerts and user segments.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
