        <mxCell id="L6-alert" value="&lt;b&gt;Flash Sale Alert&lt;/b&gt;&lt;br&gt;Real-time notification&lt;br&gt;Written to flash_sale_alerts&lt;br&gt;+ console / webhook" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b71c1c;strokeColor=#7f0000;fontSize=10;fontColor=#ffffff;fontStyle=1;" parent="L6" vertex="1">
