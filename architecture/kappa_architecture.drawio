        <mxCell id="L6-arch" value="&lt;b&gt;Architecture: KAPPA&lt;/b&gt;&lt;br&gt;No Lambda batch layer.&lt;br&gt;Airflow queries the same&lt;br&gt;streaming store." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#37474f;strokeColor=#263238;fontSize=10;fontColor=#eceff1;" parent="L6" vertex="1">
