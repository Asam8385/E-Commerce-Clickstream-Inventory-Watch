        <mxCell id="L6-top5" value="&lt;b&gt;top_products_&lt;date&gt;.txt&lt;/b&gt;&lt;br&gt;Ranked list of top 5 products&lt;br&gt;with views, purchases&lt;br&gt;and conversion rates" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=10;" parent="L6" vertex="1">
